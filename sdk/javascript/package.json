{
  "name": "biq-api",
  "version": "2.0.0",
  "description": "Official JavaScript/TypeScript SDK for BabiesIQ API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run"
  },
  "keywords": ["babiesiq", "biq-api", "youtube", "audio", "video", "streaming", "sdk"],
  "author": "BabiesIQ Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BabiesIQ/_metaAPI"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
